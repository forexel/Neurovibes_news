# App
APP_ENV=development

# Postgres
POSTGRES_DB=news_publisher
POSTGRES_USER=news_user
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+psycopg://news_user:change_me@db:5432/news_publisher

# OpenRouter / OpenAI-compatible
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_RETRIES=2
OPENROUTER_API_KEY=<YOUR_OPENROUTER_KEY>
LLM_TEXT_MODEL=openai/gpt-4o-mini
LLM_IMAGE_MODEL=openai/gpt-5.2-chat
EMBEDDING_MODEL=openai/text-embedding-3-small

# Telegram
TELEGRAM_BOT_TOKEN=<YOUR_TELEGRAM_BOT_TOKEN>
TELEGRAM_CHANNEL_ID=@your_channel_or_id
TELEGRAM_REVIEW_CHAT_ID=<YOUR_PRIVATE_CHAT_ID_OR_USERNAME>
TELEGRAM_SIGNATURE=@neuro_vibes_future
AUTO_PUBLISH_CONFIDENCE_THRESHOLD=0.82
AUTO_PUBLISH_UNCERTAINTY_THRESHOLD=0.18

# Auth
JWT_SECRET=change_this_in_production
JWT_ALGO=HS256
JWT_TTL_MINUTES=720
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=admin123

# Style/quality
MAX_SUMMARY_CHARS=1400
MAX_TITLE_CHARS=130
BANNED_PHRASES=шок!,ты не поверишь
AI_PREFILTER_ENABLED=true
AI_PREFILTER_KEYWORDS=ai,artificial intelligence,llm,large language model,generative,ai agent,ai agents,openai,anthropic,deepmind,chatgpt,gemini,claude,transformer,fine-tuning,model inference,neural,chips,compute,gpu,nvidia,robotics
MIN_RELEVANCE_FOR_CONTENT=7
TECHNICAL_FILTER_ENABLED=true
TECHNICAL_FILTER_BUSINESS_IT_MAX=7.4
TECHNICAL_FILTER_SIGNIFICANCE_MAX=8.8
DEEP_TECHNICAL_FILTER_ENABLED=true
DEEP_TECHNICAL_FILTER_BUSINESS_IT_MAX=8.5
DEEP_TECHNICAL_FILTER_SIGNIFICANCE_MAX=9.2
DEEP_TECHNICAL_FILTER_RELEVANCE_MAX=9.4
DEEP_TECHNICAL_KEYWORDS=benchmark,parameterized logical,sat,petri net,theorem,proof,ablation,architecture search,diffusion equation,formal verification,retrosynthesis
INVESTING_FILTER_ENABLED=true
INVESTING_FILTER_BUSINESS_IT_MAX=8.0
INVESTING_FILTER_SIGNIFICANCE_MAX=8.9
INVESTING_FILTER_RELEVANCE_MAX=9.0
MASS_AUDIENCE_FILTER_ENABLED=true
MASS_AUDIENCE_SIGNIFICANCE_MAX=9.1
MASS_AUDIENCE_RELEVANCE_MAX=9.2
MASS_AUDIENCE_BUSINESS_IT_MAX=8.6
MASS_AUDIENCE_WOW_KEYWORDS=new version,release,launched,rollout,available now,security,privacy,data breach,safety,major update,first in world,breakthrough,wow
AUTO_SCORE_ON_INGEST=true
BROWSER_FETCH_ENABLED=true
BROWSER_FETCH_DOMAINS=forbes.com,wired.com,bloomberg.com,ft.com,businessinsider.com,openai.com
BROWSER_COOKIES_JSON=

# MinIO image storage
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=news-images
MINIO_USE_SSL=false
MINIO_PUBLIC_BASE_URL=http://localhost:9010
MINIO_COMPRESS_ENABLED=true
MINIO_COMPRESS_FORMAT=WEBP
MINIO_COMPRESS_QUALITY=82
MINIO_MAX_WIDTH=1920

# Pipeline worker (optional background cycle)
WORKER_INTERVAL_SECONDS=3600
WORKER_BACKFILL_DAYS=1
SCHEDULE_TICK_SECONDS=30
# UTC times for auto-publish (2/day example):
AUTO_PUBLISH_TIMES_UTC=09:00,18:00

# Dedup/Scoring tuning
DEDUP_SIMILARITY_THRESHOLD=0.86
SOURCE_TRUST_DEFAULT=7.0
W_SIGNIFICANCE=0.25
W_FRESHNESS=0.15
W_RELEVANCE=0.20
W_VIRALITY=0.15
W_UNIQUENESS=0.10
W_LONGEVITY=0.10
W_SCALE=0.05
W_SOURCE_TRUST=0.10

# Approximate LLM cost estimation (USD per 1M tokens)
LLM_CHAT_INPUT_COST_PER_MTOK=0.15
LLM_CHAT_OUTPUT_COST_PER_MTOK=0.60
LLM_EMBED_INPUT_COST_PER_MTOK=0.02
