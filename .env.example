# App
APP_ENV=development

# Postgres
POSTGRES_DB=news_publisher
POSTGRES_USER=news_user
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+psycopg://news_user:change_me@db:5432/news_publisher

# OpenRouter / OpenAI-compatible
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_RETRIES=2
OPENROUTER_API_KEY=<YOUR_OPENROUTER_KEY>
LLM_TEXT_MODEL=openai/gpt-4o-mini
LLM_IMAGE_MODEL=openai/gpt-5.2-chat
EMBEDDING_MODEL=openai/text-embedding-3-small

# Telegram
TELEGRAM_BOT_TOKEN=<YOUR_TELEGRAM_BOT_TOKEN>
TELEGRAM_CHANNEL_ID=@your_channel_or_id
TELEGRAM_REVIEW_CHAT_ID=<YOUR_PRIVATE_CHAT_ID_OR_USERNAME>
TELEGRAM_SIGNATURE=@neuro_vibes_future
AUTO_PUBLISH_CONFIDENCE_THRESHOLD=0.82
AUTO_PUBLISH_UNCERTAINTY_THRESHOLD=0.18

# Auth
JWT_SECRET=change_this_in_production
JWT_ALGO=HS256
JWT_TTL_MINUTES=720
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=admin123

# Runtime style/quality filters are stored in DB table `runtime_settings`
# and managed from /admin/score.
AUTO_SCORE_ON_INGEST=true
BROWSER_COOKIES_JSON=

# MinIO image storage
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=news-images
MINIO_USE_SSL=false
MINIO_PUBLIC_BASE_URL=http://localhost:9010
MINIO_COMPRESS_ENABLED=true
MINIO_COMPRESS_FORMAT=WEBP
MINIO_COMPRESS_QUALITY=82
MINIO_MAX_WIDTH=1920

# Pipeline worker (optional background cycle)
WORKER_INTERVAL_SECONDS=3600
WORKER_BACKFILL_DAYS=1
SCHEDULE_TICK_SECONDS=30
# UTC times for auto-publish (2/day example):
AUTO_PUBLISH_TIMES_UTC=09:00,18:00

# Dedup/Scoring tuning
DEDUP_SIMILARITY_THRESHOLD=0.86
SOURCE_TRUST_DEFAULT=7.0
W_SIGNIFICANCE=0.25
W_FRESHNESS=0.15
W_RELEVANCE=0.20
W_VIRALITY=0.15
W_UNIQUENESS=0.10
W_LONGEVITY=0.10
W_SCALE=0.05
W_SOURCE_TRUST=0.10

# Approximate LLM cost estimation (USD per 1M tokens)
LLM_CHAT_INPUT_COST_PER_MTOK=0.15
LLM_CHAT_OUTPUT_COST_PER_MTOK=0.60
LLM_EMBED_INPUT_COST_PER_MTOK=0.02
